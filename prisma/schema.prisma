generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  HOLD
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum InquiryType {
  QUERY
  FEEDBACK
}

model Booking {
  id          String        @id @default(cuid())
  startTime   DateTime
  endTime     DateTime
  name        String?
  age         Int?
  email       String?
  phone       String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  confirmedAt DateTime?
  status      BookingStatus @default(HOLD)
  holdExpires DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  caseSheet   CaseSheet?

  @@index([startTime])
  @@index([status])
  @@index([holdExpires])
  @@index([razorpayOrderId])
}

model CaseSheet {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  caseSummary    String?
  medicationPlan String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model Inquiry {
  id        String      @id @default(cuid())
  type      InquiryType
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([type])
  @@index([createdAt])
}
